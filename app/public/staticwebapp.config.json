{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/*.js",
      "/*.css",
      "/*.svg",
      "/*.png",
      "/*.ico",
      "/*.json",
      "/*.webmanifest",
      "/sw.js",
      "/workbox-*.js",
      "/registerSW.js"
    ]
  },
  "mimeTypes": {
    ".js": "text/javascript",
    ".mjs": "text/javascript",
    ".css": "text/css",
    ".json": "application/json",
    ".webmanifest": "application/manifest+json",
    ".svg": "image/svg+xml"
  }
}
